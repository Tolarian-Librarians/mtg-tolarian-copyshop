<Controls:MetroWindow x:Class="Tolarian.Copyshop.ScreenPresenter.Views.CopyShopView"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="http://metro.mahapps.com/winfx/xaml/controls"
                      xmlns:Dialog="clr-namespace:MahApps.Metro.Controls.Dialogs;assembly=MahApps.Metro"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                      xmlns:local="clr-namespace:Tolarian.Copyshop.ScreenPresenter.Views"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:vm="clr-namespace:Tolarian.Copyshop.ScreenPresenter.ViewModels"
                      Title="Tolarian Copyshop"
                      MinWidth="1200"
                      MinHeight="600"
                      Dialog:DialogParticipation.Register="{Binding}"
                      d:DataContext="{d:DesignInstance Type=vm:CopyShopDesignViewModel,
                                                       IsDesignTimeCreatable=True}"
                      DataContext="{Binding Path=CopyShopViewModel, Source={StaticResource ServiceLocator}}"
                      mc:Ignorable="d">

    <Controls:MetroWindow.LeftWindowCommands>
        <Controls:WindowCommands />
    </Controls:MetroWindow.LeftWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition Height="*" />
            <RowDefinition Height="20" />
        </Grid.RowDefinitions>
        <Menu>
            <MenuItem Header="FILE">
                <MenuItem Command="{Binding NewCommand}" Header="New">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="FileAltSolid" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Command="{Binding OpenCommand}" Header="Open">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="FolderOpenSolid" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Command="{Binding SaveCommand}" Header="Save">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="SaveSolid" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Command="{Binding SaveToCommand}" Header="Save to">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="HddSolid" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="Import from ...">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="FileImportSolid" />
                    </MenuItem.Icon>
                    <MenuItem Command="{Binding ImportTextCommand}" Header="Import from Text">
                        <MenuItem.Icon>
                            <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="EnvelopeOpenTextSolid" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="Export to ..." IsEnabled="False">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="ShareSquareSolid" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="EDIT">
                <MenuItem Command="{Binding ClearCommand}" Header="Clear Decklist">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="TrashAltSolid" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="ACTION">
                <MenuItem Command="{Binding PrintCommand}" Header="Print Deck">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="PrintSolid" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="HELP">
                <MenuItem Header="About Tolarian Copyshop">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="AddressCardSolid" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Tolarian Copyshop on GitHub">
                    <MenuItem.Icon>
                        <iconPacks:PackIconFontAwesome Height="16" Margin="4,0,0,0" Kind="GithubSquareBrands" />
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1">
            <TabItem Header="Build Deck">
                <local:DeckBuilderView x:Name="_DeckBuilderView" />
            </TabItem>
            <TabItem Header="View Deck">
                <local:DeckViewerView x:Name="_DeckViewerView" />
            </TabItem>
        </TabControl>
        <StatusBar Grid.Row="2">
            <StatusBarItem Content="Total Cards:" />
            <StatusBarItem Content="{Binding ElementName=_DeckBuilderView, Path=DataContext.DeckCardCount}" />
        </StatusBar>
    </Grid>
</Controls:MetroWindow>
